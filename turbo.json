{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "ios": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build", "pod-install"]
    },
    "android": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "pod-install": {
      "cache": false,
      "inputs": ["apps/mobile/ios/Podfile"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
} 